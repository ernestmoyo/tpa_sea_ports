generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum UserRole {
  ADMIN
  OPERATIONS
  WAREHOUSE
  BILLING
  FINANCE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          UserRole  @default(OPERATIONS)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  operations    CargoOperation[]
  invoices      Invoice[]
  complaints    Complaint[]      @relation("AssignedComplaints")
  slaLogs       SLALog[]
}

// ============================================================================
// TARIFF SYSTEM (TPA Tariff Book Feb 2024 - All 43 Clauses)
// ============================================================================

model TariffClause {
  id            String    @id @default(cuid())
  clauseNumber  Int       @unique
  title         String
  description   String?   @db.Text
  partNumber    Int       // Part I-V of the tariff book
  effectiveDate DateTime  @default(now())
  isActive      Boolean   @default(true)

  rates         TariffRate[]
  freePeriods   TariffFreePeriod[]
}

enum RateUnit {
  PER_HTN              // Per Harbour Tonne
  PER_DWT              // Per Deadweight Tonne
  PER_TEU              // Per Twenty-foot Equivalent Unit
  PER_CONTAINER_20FT
  PER_CONTAINER_40FT
  PER_100_GRT          // Per 100 Gross Registered Tonnage
  PER_GRT
  PER_HOUR
  PER_DAY
  PER_SHIFT
  PER_OPERATION
  PER_CALL
  PER_TRIP
  PER_MAN_HOUR
  PER_MINUTE
  PER_PACKAGE
  PER_BAG
  PER_ANIMAL
  PER_LITRE
  PER_METRE
  PER_PERSON
  AD_VALOREM           // Percentage of CIF value
  FIXED                // Fixed rate
  PER_TONNE_CAPACITY   // For lighters/pontoons
  PER_RECEPTACLE
  PER_50KG
}

enum VesselCategory {
  DEEP_SEA
  COASTER
  TRADITIONAL
  ALL
}

enum CargoClassification {
  DOMESTIC_IMPORT
  DOMESTIC_EXPORT
  TRANSIT_IMPORT
  TRANSIT_EXPORT
  TRANSSHIPMENT
  COASTWISE
  ALL
}

enum ContainerLoadType {
  FCL
  LCL
  EMPTY
  ALL
}

model TariffRate {
  id                String              @id @default(cuid())
  clauseId          String
  clause            TariffClause        @relation(fields: [clauseId], references: [id])
  serviceCode       String              // Unique code for the service e.g. "PILOT_ENTER", "STORAGE_DOM_FCL_T1"
  serviceName       String              // Human-readable name
  subClause         String?             // e.g. "1(a)", "2(b)(i)"
  vesselCategory    VesselCategory      @default(ALL)
  cargoClass        CargoClassification @default(ALL)
  containerSize     String?             // "20", "40", null for non-container
  containerLoadType ContainerLoadType   @default(ALL)
  rateAmount        Decimal             @db.Decimal(12, 2)
  rateUnit          RateUnit
  isMinimum         Boolean             @default(false)
  minimumAmount     Decimal?            @db.Decimal(12, 2)
  isOvertime        Boolean             @default(false)
  overtimeRate      Decimal?            @db.Decimal(12, 2)
  notes             String?             @db.Text
  isActive          Boolean             @default(true)

  invoiceLineItems  InvoiceLineItem[]

  @@index([clauseId])
  @@index([serviceCode])
}

enum SurchargeType {
  DANGEROUS_GOODS_HANDLING   // +10% on stevedoring/shorehandling
  DANGEROUS_GOODS_STORAGE    // +20% on storage
  OVER_DIMENSION             // +30% on handling
  COLD_STORAGE               // +30% on handling
  OVERTIME                   // Variable
  VAT                        // As applicable
}

model TariffSurcharge {
  id                String        @id @default(cuid())
  surchargeType     SurchargeType
  percentage        Decimal       @db.Decimal(5, 2)
  description       String
  appliesToClauses  String[]      // Clause numbers as strings
  isActive          Boolean       @default(true)
}

model TariffFreePeriod {
  id              String              @id @default(cuid())
  clauseId        String
  clause          TariffClause        @relation(fields: [clauseId], references: [id])
  cargoClass      CargoClassification
  containerSize   String?             // "20", "40", null
  freeDays        Int
  freeHours       Int?                // For reefer (48hr) and DG (24hr)
  description     String?

  @@index([clauseId])
}

// ============================================================================
// CUSTOMERS
// ============================================================================

enum CustomerType {
  IMPORTER
  EXPORTER
  SHIPPING_AGENT
  CLEARING_AGENT
  SHIP_OWNER
  TERMINAL_OPERATOR
  TRANSIT_CLIENT
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  customerType  CustomerType
  companyName   String?
  country       String        @default("TZ") // TZ, ZM, CD, BI, RW, MW, UG, ZW
  address       String?
  phone         String?
  email         String?
  taxId         String?       // TIN number
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  containers    Container[]
  cargos        Cargo[]
  invoices      Invoice[]
  complaints    Complaint[]
  documents     Document[]
}

// ============================================================================
// VESSELS
// ============================================================================

enum VesselType {
  CONTAINER_SHIP
  BULK_CARRIER
  TANKER
  RORO
  GENERAL_CARGO
  DHOW
  COASTER
  TRADITIONAL
  PLEASURE_CRAFT
  TUG
  OTHER
}

model Vessel {
  id            String      @id @default(cuid())
  name          String
  imoNumber     String?     @unique
  grt           Decimal     @db.Decimal(12, 2) // Gross Registered Tonnage
  dwt           Decimal?    @db.Decimal(12, 2) // Deadweight Tonnage
  loa           Decimal?    @db.Decimal(8, 2)  // Length Overall (metres)
  vesselType    VesselType
  flagState     String?
  isCoaster     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  vesselCalls   VesselCall[]
}

enum VesselCallStatus {
  EXPECTED
  ARRIVED
  BERTHED
  WORKING
  COMPLETED
  DEPARTED
}

model VesselCall {
  id              String            @id @default(cuid())
  vesselId        String
  vessel          Vessel            @relation(fields: [vesselId], references: [id])
  voyageNumber    String?
  eta             DateTime?
  ata             DateTime?         // Actual time of arrival
  atd             DateTime?         // Actual time of departure
  berth           String?
  status          VesselCallStatus  @default(EXPECTED)
  dischargeDate   DateTime?         // Date vessel completes discharge
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  containers      Container[]
  invoices        Invoice[]

  @@index([vesselId])
}

// ============================================================================
// CONTAINERS
// ============================================================================

enum ContainerSize {
  SIZE_20
  SIZE_40
  SIZE_45
}

enum ContainerType {
  DRY
  REEFER
  OPEN_TOP
  FLAT_RACK
  TANK
  OTHER
}

enum ContainerStatus {
  ARRIVING
  RECEIVED
  IN_STORAGE
  UNDER_OPERATION
  READY_FOR_RELEASE
  RELEASED
  DEPARTED
}

model Container {
  id                String          @id @default(cuid())
  containerNumber   String          @unique // ISO 6346 format
  size              ContainerSize
  containerType     ContainerType   @default(DRY)
  status            ContainerStatus @default(ARRIVING)
  isFcl             Boolean         @default(true)
  isEmpty           Boolean         @default(false)
  isOverDimension   Boolean         @default(false)
  tareWeight        Decimal?        @db.Decimal(10, 2)
  vgmWeight         Decimal?        @db.Decimal(10, 2) // SOLAS VGM
  vgmCertified      Boolean         @default(false)
  sealNumber        String?

  customerId        String?
  customer          Customer?       @relation(fields: [customerId], references: [id])
  vesselCallId      String?
  vesselCall        VesselCall?     @relation(fields: [vesselCallId], references: [id])

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  cargos            ContainerCargo[]
  storageBookings   StorageBooking[]
  reeferLogs        ReeferMonitoring[]
  reeferPowerLogs   ReeferPowerLog[]
  operations        CargoOperation[]
  documents         Document[]
  dangerousGoods    DangerousGoods[]

  @@index([customerId])
  @@index([vesselCallId])
  @@index([status])
}

// ============================================================================
// CARGO
// ============================================================================

enum CargoType {
  DOMESTIC_IMPORT
  DOMESTIC_EXPORT
  TRANSIT_IMPORT
  TRANSIT_EXPORT
  TRANSSHIPMENT
  COASTWISE
}

model Cargo {
  id              String    @id @default(cuid())
  description     String
  hsCode          String?   // Harmonized System code
  weightKg        Decimal   @db.Decimal(12, 2)
  volumeCbm       Decimal?  @db.Decimal(12, 2)
  harbourTonnes   Decimal   @db.Decimal(12, 2) // max(weight/1000, volume)
  cifValueUsd     Decimal?  @db.Decimal(14, 2)
  cargoType       CargoType
  isDangerous     Boolean   @default(false)
  isColdStorage   Boolean   @default(false)
  isValuable      Boolean   @default(false)
  packageCount    Int?
  destinationCountry String? // For transit: ZM, CD, BI, RW, MW, UG, ZW

  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  containers      ContainerCargo[]
  operations      CargoOperation[]
  dangerousGoods  DangerousGoods[]
  documents       Document[]

  @@index([customerId])
  @@index([cargoType])
}

model ContainerCargo {
  id            String    @id @default(cuid())
  containerId   String
  container     Container @relation(fields: [containerId], references: [id])
  cargoId       String
  cargo         Cargo     @relation(fields: [cargoId], references: [id])

  @@unique([containerId, cargoId])
}

// ============================================================================
// DANGEROUS GOODS (IMDG Code Compliance)
// ============================================================================

enum IMDGClass {
  CLASS_1    // Explosives
  CLASS_2_1  // Flammable gases
  CLASS_2_2  // Non-flammable gases
  CLASS_2_3  // Toxic gases
  CLASS_3    // Flammable liquids
  CLASS_4_1  // Flammable solids
  CLASS_4_2  // Spontaneously combustible
  CLASS_4_3  // Dangerous when wet
  CLASS_5_1  // Oxidizing substances
  CLASS_5_2  // Organic peroxides
  CLASS_6_1  // Toxic substances
  CLASS_6_2  // Infectious substances
  CLASS_7    // Radioactive material
  CLASS_8    // Corrosives
  CLASS_9    // Miscellaneous
}

enum PackingGroup {
  I     // Great danger
  II    // Medium danger
  III   // Minor danger
}

model DangerousGoods {
  id                  String        @id @default(cuid())
  containerId         String?
  container           Container?    @relation(fields: [containerId], references: [id])
  cargoId             String?
  cargo               Cargo?        @relation(fields: [cargoId], references: [id])
  imdgClass           IMDGClass
  unNumber            String        // UN number e.g. "UN1203"
  properShippingName  String
  packingGroup        PackingGroup?
  flashPoint          String?
  segregationGroup    String?
  emergencySchedule   String?
  msdsDocumentId      String?
  notes               String?       @db.Text
  createdAt           DateTime      @default(now())

  @@index([containerId])
  @@index([cargoId])
  @@index([imdgClass])
}

// ============================================================================
// WAREHOUSE & STORAGE
// ============================================================================

enum WarehouseType {
  BONDED
  FREE
  REEFER_YARD
  DG_ZONE
  OPEN_YARD
}

model Warehouse {
  id              String        @id @default(cuid())
  name            String
  warehouseType   WarehouseType
  location        String?
  totalCapacityTeu Int
  currentOccupancy Int          @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  slots           StorageSlot[]
}

enum SlotType {
  STANDARD
  REEFER_POINT
  DG_ZONE
  HEAVY_LIFT
  OPEN_YARD
}

model StorageSlot {
  id            String      @id @default(cuid())
  warehouseId   String
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  slotCode      String      // e.g. "A-01-03-1" (block-bay-row-tier)
  block         String?
  bay           Int?
  row           Int?
  tier          Int?
  slotType      SlotType    @default(STANDARD)
  isOccupied    Boolean     @default(false)
  isActive      Boolean     @default(true)

  bookings      StorageBooking[]

  @@unique([warehouseId, slotCode])
  @@index([warehouseId])
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model StorageBooking {
  id              String        @id @default(cuid())
  containerId     String
  container       Container     @relation(fields: [containerId], references: [id])
  slotId          String
  slot            StorageSlot   @relation(fields: [slotId], references: [id])
  checkInDate     DateTime
  checkOutDate    DateTime?
  trafficType     CargoType     // Determines free period
  freePeriodDays  Int           // Calculated from tariff
  status          BookingStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([containerId])
  @@index([slotId])
}

// ============================================================================
// REEFER MANAGEMENT
// ============================================================================

model ReeferMonitoring {
  id              String    @id @default(cuid())
  containerId     String
  container       Container @relation(fields: [containerId], references: [id])
  timestamp       DateTime  @default(now())
  setTemperature  Decimal   @db.Decimal(5, 2) // Celsius
  actualTemperature Decimal @db.Decimal(5, 2)
  humidity        Decimal?  @db.Decimal(5, 2)
  powerStatus     Boolean   @default(true) // true = connected
  alertGenerated  Boolean   @default(false)
  alertMessage    String?

  @@index([containerId])
  @@index([timestamp])
}

model ReeferPowerLog {
  id            String    @id @default(cuid())
  containerId   String
  container     Container @relation(fields: [containerId], references: [id])
  connectDate   DateTime
  disconnectDate DateTime?
  dailyRate     Decimal   @db.Decimal(8, 2) // USD per day (8.00 for 20ft, 12.00 for 40ft)

  @@index([containerId])
}

// ============================================================================
// CARGO OPERATIONS
// ============================================================================

enum OperationType {
  RECEIVING
  PALLETISING
  STRETCH_WRAPPING
  STUFFING
  STRIPPING
  WEIGHING
  MEASURING
  FUMIGATION
  LOADING
  UNLOADING
  DELIVERY
  TRANSFER
  INSPECTION
  VGM_VERIFICATION
  SORTING
  REMOVAL
  BAGGING
}

model CargoOperation {
  id            String        @id @default(cuid())
  containerId   String?
  container     Container?    @relation(fields: [containerId], references: [id])
  cargoId       String?
  cargo         Cargo?        @relation(fields: [cargoId], references: [id])
  operationType OperationType
  performedById String?
  performedBy   User?         @relation(fields: [performedById], references: [id])
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  isOvertime    Boolean       @default(false)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())

  @@index([containerId])
  @@index([cargoId])
  @@index([operationType])
}

// ============================================================================
// BILLING & INVOICING
// ============================================================================

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  vesselCallId    String?
  vesselCall      VesselCall?   @relation(fields: [vesselCallId], references: [id])
  issuedById      String?
  issuedBy        User?         @relation(fields: [issuedById], references: [id])
  currency        String        @default("USD") // USD, TZS
  exchangeRate    Decimal?      @db.Decimal(12, 4) // TZS per USD if needed
  subtotal        Decimal       @db.Decimal(14, 2)
  vatRate         Decimal       @db.Decimal(5, 2) @default(0)
  vatAmount       Decimal       @db.Decimal(14, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(14, 2)
  status          InvoiceStatus @default(DRAFT)
  issuedDate      DateTime?
  dueDate         DateTime?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lineItems       InvoiceLineItem[]
  payments        Payment[]

  @@index([customerId])
  @@index([status])
}

model InvoiceLineItem {
  id              String      @id @default(cuid())
  invoiceId       String
  invoice         Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tariffRateId    String?
  tariffRate      TariffRate? @relation(fields: [tariffRateId], references: [id])
  description     String
  clauseReference String?     // e.g. "Clause 32.2(a)(ii)"
  quantity        Decimal     @db.Decimal(12, 2)
  unitRate        Decimal     @db.Decimal(12, 2)
  surchargeType   String?     // "DG_10", "DG_20", "OVERDIM_30", "COLD_30"
  surchargeAmount Decimal     @db.Decimal(12, 2) @default(0)
  lineTotal       Decimal     @db.Decimal(14, 2)

  @@index([invoiceId])
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CHEQUE
  MOBILE_MONEY
  CREDIT
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  currency        String        @default("USD")
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  reference       String?
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([invoiceId])
}

// ============================================================================
// DOCUMENTS & COMPLIANCE
// ============================================================================

enum DocumentType {
  BILL_OF_LADING
  DELIVERY_ORDER
  RELEASE_ORDER
  CUSTOMS_DECLARATION
  MSDS
  SHIPPING_ORDER
  MANIFEST
  VGM_CERTIFICATE
  TANCIS_ENTRY
  PACKING_LIST
  COMMERCIAL_INVOICE
  CERTIFICATE_OF_ORIGIN
  FUMIGATION_CERTIFICATE
  DG_DECLARATION
  OTHER
}

model Document {
  id            String        @id @default(cuid())
  documentType  DocumentType
  documentNumber String?
  fileName      String
  filePath      String?
  containerId   String?
  container     Container?    @relation(fields: [containerId], references: [id])
  cargoId       String?
  cargo         Cargo?        @relation(fields: [cargoId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  notes         String?
  uploadedAt    DateTime      @default(now())
  receivedAt    DateTime?
  processedAt   DateTime?

  @@index([containerId])
  @@index([cargoId])
  @@index([documentType])
}

// ============================================================================
// SLA & COMPLAINTS (TPA Charter Compliance)
// ============================================================================

enum SLAServiceType {
  DOCUMENT_PROCESSING     // Target: 15 minutes
  CARGO_OPERATIONS        // Target: 60 minutes (commence within 1hr)
  CUSTOMER_INQUIRY        // Target: 5 minutes (digital), 3 min (walk-in)
  WRITTEN_CORRESPONDENCE  // Target: 1 working day acknowledgement
  EMAIL_QUERY             // Target: 1 hour
  DETAILED_ANALYSIS       // Target: 3 working days ack, 14 days resolve
  RECEPTION_DESK          // Target: 5 minutes
  DEPARTMENT_VISIT        // Target: 15 min (with appt), 30 min (without)
  PHONE_CALL              // Target: 5 seconds
  PILOTAGE                // Target: 1 hour
}

model SLALog {
  id              String          @id @default(cuid())
  serviceType     SLAServiceType
  targetMinutes   Int             // SLA target in minutes
  startedAt       DateTime
  completedAt     DateTime?
  actualMinutes   Int?
  metTarget       Boolean?
  performedById   String?
  performedBy     User?           @relation(fields: [performedById], references: [id])
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([serviceType])
  @@index([metTarget])
}

enum ComplaintStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

model Complaint {
  id            String          @id @default(cuid())
  customerId    String?
  customer      Customer?       @relation(fields: [customerId], references: [id])
  category      String
  description   String          @db.Text
  status        ComplaintStatus  @default(OPEN)
  resolution    String?         @db.Text
  assignedToId  String?
  assignedTo    User?           @relation("AssignedComplaints", fields: [assignedToId], references: [id])
  openedAt      DateTime        @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([customerId])
  @@index([status])
}
